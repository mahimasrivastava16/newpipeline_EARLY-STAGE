# Aggregate duplicate antibody channels by mean if present
if (any(duplicated(rownames(rppa_normalized)))) {
  cat("Aggregating duplicate antibody rows by mean score...\n")
  rppa_normalized <- aggregate(rppa_normalized, by = list(rownames(rppa_normalized)), FUN = mean)
  rownames(rppa_normalized) <- rppa_normalized$Group.1
  rppa_normalized$Group.1 <- NULL
  rppa_normalized <- as.matrix(rppa_normalized)
}

# 1.7.4: ComBat Pass with Integrated Biological Sensitivity Check
# Isolate singletons to protect degrees of freedom
plate_counts <- table(rppa_metadata$plate_id)
singleton_plates <- names(plate_counts)[plate_counts <= 1]

if (length(singleton_plates) > 0) {
  valid_samples <- !rppa_metadata$plate_id %in% singleton_plates
  rppa_normalized_working <- rppa_normalized[, valid_samples, drop = FALSE]
  rppa_metadata_working <- rppa_metadata[valid_samples, , drop = FALSE]
} else {
  rppa_normalized_working <- rppa_normalized
  rppa_metadata_working <- rppa_metadata
}

batch_vector <- as.factor(rppa_metadata_working$plate_id)
mod_matrix <- model.matrix(~ as.factor(class), data = rppa_metadata_working)

cat("Executing primary ComBat batch adjustment pass...\n")
rppa_combat <- tryCatch({
  ComBat(dat = rppa_normalized_working, 
         batch = batch_vector, 
         mod = mod_matrix, 
         par.prior = TRUE, 
         prior.plots = FALSE)
}, error = function(e) {
  cat("ComBat failed due to matrix mathematical variance bounds. Shifting to fallback fallback mode.\n")
  return(NULL)
})

# --- BIOLOGICAL SENSITIVITY CHECK SYSTEM ---
# Confirm ERBB2 and ESR1 signatures retain expected physiological ranges post-correction
run_fallback <- FALSE

if (is.null(rppa_combat)) {
  run_fallback <- TRUE
} else {
  # Search for target strings within the antibody naming scheme (e.g., "Her2", "ER-alpha", "ESR1")
  erbb2_row <- grep("ERBB2|HER2", rownames(rppa_combat), ignore.case = TRUE, value = TRUE)
  esr1_row  <- grep("ESR1|ER-ALPHA", rownames(rppa_combat), ignore.case = TRUE, value = TRUE)
  
  if (length(erbb2_row) > 0 && length(esr1_row) > 0) {
    # Check if the overall global variance of these critical markers was overly compressed
    var_erbb2_post <- var(rppa_combat[erbb2_row[1], ])
    var_erbb2_pre  <- var(rppa_normalized_working[erbb2_row[1], ])
    
    # Rule: If ComBat squashes the variance of key markers by more than 70%, it is over-correcting
    if ((var_erbb2_post / var_erbb2_pre) < 0.30) {
      cat("Warning: ComBat compression exceeded biological safety metrics (>70% variance loss for ERBB2).\n")
      run_fallback <- TRUE
    }
  }
}

if (run_fallback) {
  cat("Executing alternative protocol: Median-centering across batches to protect signal architecture.\n")
  # Alternative protocol: Sample median-centering within individual batches
  rppa_final <- rppa_normalized_working
  unique_batches <- unique(rppa_metadata_working$plate_id)
  
  for (b in unique_batches) {
    b_idx <- which(rppa_metadata_working$plate_id == b)
    if (length(b_idx) > 0) {
      batch_medians <- apply(rppa_final[, b_idx, drop = FALSE], 1, median, na.rm = TRUE)
      rppa_final[, b_idx] <- rppa_final[, b_idx, drop = FALSE] - batch_medians
    }
  }
  normalization_method_used <- "MedianCentering"
} else {
  cat("ComBat biological validation pass successful. Signal boundaries intact.\n")
  rppa_final <- rppa_combat
  normalization_method_used <- "ComBat"
}

# Save processed matrix structures alongside the validation log
saveRDS(list(matrix = rppa_final, metadata = rppa_metadata_working, method = normalization_method_used), 
        file = file.path(config$out_dir, "rppa_normalized_corrected.rds"))
cat("Step 1.7 Complete: Processed RPPA proteomic matrix saved.\n")
