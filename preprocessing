rm(data) # Purge reference copy immediately to reclaim RAM

# 1.3.2: Map the SummarizedExperiment sample IDs to match your 15-char metadata keys
raw_rna_barcodes <- colnames(rna_se)
colnames(rna_se)  <- substr(raw_rna_barcodes, 1, 15)

