cat("\nProcessing Copy Number Variation Layer (Step 1.6)...\n")

# 1.6.1: Load raw CNV segment data from your local download path
load(file.path(config$raw_dir, "cnv.rda"))

# TCGAbiolinks saves Masked Copy Number Segment files as an object named 'data'
if (!exists("data")) {
  stop("Expected object named 'data' was not found in the loaded cnv.rda file.")
}
cnv_raw <- data
rm(data) # Free memory immediately

# GDC copy number segment dataframes contain columns: Sample, Chromosome, Start, End, Num_Probes, Segment_Mean
cnv_df <- as.data.frame(cnv_raw)

# Standardize column sample identifiers to match your 15-character tracking key
cnv_df$sample_barcode_15 <- substr(cnv_df$Sample, 1, 15)

# Intersect and slice table down to your synchronized registry baseline
cnv_df_aligned <- cnv_df %>% 
  filter(sample_barcode_15 %in% meta_matrix$sample_barcode_15)

# 1.6.2: Set Up hg19 Genomic Ranges reference
library(GenomicRanges)
library(TxDb.Hsapiens.UCSC.hg19.knownGene)

txdb <- TxDb.Hsapiens.UCSC.hg19.knownGene
hg19_genes <- genes(txdb) # Extract core hg19 gene coordinates

# Convert raw segment data frame into an indexed GRanges collection
# Coerce "X" and "Y" coordinates if present to match UCSC styles ("chrX", "chrY")
cnv_df_aligned$Chromosome <- ifelse(startsWith(as.character(cnv_df_aligned$Chromosome), "chr"),
                                    as.character(cnv_df_aligned$Chromosome),
                                    paste0("chr", cnv_df_aligned$Chromosome))

segments_gr <- GRanges(
  seqnames = cnv_df_aligned$Chromosome,
  ranges   = IRanges(start = cnv_df_aligned$Start, end = cnv_df_aligned$End),
  Segment_Mean   = cnv_df_aligned$Segment_Mean,
  sample_barcode = cnv_df_aligned$sample_barcode_15
)

# 1.6.3: Length-Weighted Genomic Overlap Optimization Loop
cat("Executing length-weighted mean gene-level collapse across all target samples...\n")

unique_cnv_samples <- unique(segments_gr$sample_barcode)
gene_ids <- names(hg19_genes)

# Pre-allocate blank score storage grid [Genes x Samples]
cnv_gene_matrix <- matrix(NA, nrow = length(gene_ids), ncol = length(unique_cnv_samples),
                          dimnames = list(gene_ids, unique_cnv_samples))

# Find overlapping pairs across the whole coordinate layout at once to optimize lookups
overlap_hits <- findOverlappingPairs(hg19_genes, segments_gr)

# Convert hits metadata to data frame for rapid vectorized calculations via data.table
overlap_dt <- data.table(
  gene_id        = names(first(overlap_hits)),
  sample_barcode = second(overlap_hits)$sample_barcode,
  seg_mean       = second(overlap_hits)$Segment_Mean,
  g_start        = start(first(overlap_hits)),
  g_end          = end(first(overlap_hits)),
  s_start        = start(second(overlap_hits)),
  s_end          = end(second(overlap_hits))
)

# Calculate nucleotide overlap bounds per intersection match
overlap_dt[, overlap_start := pmax(g_start, s_start)]
overlap_dt[, overlap_end   := pmin(g_end, s_end)]
overlap_dt[, overlap_len   := pmax(0, overlap_end - overlap_start + 1)]

# Compute the length-weighted segment mean calculation per gene per sample
# Formula: Score = Sum(Segment_Mean * Overlap_Length) / Sum(Overlap_Length)
collapsed_dt <- overlap_dt[, .(
  weighted_score = sum(seg_mean * overlap_len) / sum(overlap_len)
), by = .(gene_id, sample_barcode)]

# Cast data.table back into standard matrix dimensions
for (s in unique_cnv_samples) {
  sample_subset <- collapsed_dt[sample_barcode == s]
  cnv_gene_matrix[sample_subset$gene_id, s] <- sample_subset$weighted_score
}

# 1.6.4: Handle Sample Quality Control Flags (> 30% missing rows dropped)
