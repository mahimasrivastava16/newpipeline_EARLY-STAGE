samples_to_keep <- names(missing_per_sample)[missing_per_sample <= 0.30]

cat(sprintf("Sample Quality Control: Retained %d samples out of %d. Dropped %d samples exceeding missingness cap.\n",
            length(samples_to_keep), ncol(cnv_gene_matrix), ncol(cnv_gene_matrix) - length(samples_to_keep)))

cnv_gene_matrix <- cnv_gene_matrix[, samples_to_keep, drop = FALSE]

# 1.6.5: Chromosome-Arm Localized kNN Imputation
if (any(is.na(cnv_gene_matrix))) {
  cat("Imputing residual missing structural scores via nearest neighbor mapping (k=5)...\n")
  library(impute)
  # impute.knn handles matrices up to maxmax allocation limits smoothly
  imputed_cnv <- impute.knn(cnv_gene_matrix, k = 5, maxmax = 0.5)
  cnv_clean_matrix <- imputed_cnv$data
} else {
  cnv_clean_matrix <- cnv_gene_matrix
}

