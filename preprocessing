# Construct a clean colData dataframe for DESeq2 processing
mrna_metadata <- meta_matrix[match(mrna_samples, meta_matrix$sample_barcode_15), ]
mrna_metadata$plate_id <- mrna_plates[match(mrna_samples, colnames(rna_se))]

# 1.3.4: Low-count Filtering (Drop if < 10 counts in > 80% of samples)
raw_counts <- assay(rna_se_aligned, "unstranded") # Standard GDC HTSeq raw count assay

absence_threshold <- 0.80
min_count <- 10
absent_percentage <- rowMeans(raw_counts < min_count)
keep_genes <- absent_percentage <= absence_threshold

# Hard-enforce retention of key literature markers to avoid silent dropping
lit_targets <- c("ESR1", "ERBB2", "BRCA1", "LAD1", "COL11A1", "MAPK11", "EPYC")
genes_to_keep <- names(keep_genes)[keep_genes]

# Convert Ensembl IDs to symbols using internal rowData to ensure matching
gene_annotation <- as.data.frame(rowData(rna_se_aligned))
lit_ensembl_ids <- gene_annotation$gene_id[gene_annotation$gene_name %in% lit_targets]

final_genes_to_keep <- unique(c(genes_to_keep, lit_ensembl_ids))
counts_filtered <- raw_counts[final_genes_to_keep, ]

cat(sprintf("mRNA Filter Summary: Retained %d genes out of %d raw features.\n", 
            nrow(counts_filtered), nrow(raw_counts)))

# 1.3.5: DESeq2 Unsupervised Size-Factor Estimation and VST
dds <- DESeqDataSetFromMatrix(countData = counts_filtered,
                              colData = mrna_metadata,
                              design = ~ 1) # Unsupervised placeholder

cat("Estimating size factors and running VST...\n")
dds <- estimateSizeFactors(dds)
vst_matrix <- assay(varianceStabilizingTransformation(dds, blind = TRUE))

# 1.3.6: ComBat Batch Correction across Plate IDs
# Remove singleton plates to protect linear model degrees of freedom
plate_counts <- table(mrna_metadata$plate_id)
singleton_plates <- names(plate_counts)[plate_counts <= 1]

if(length(singleton_plates) > 0) {
  cat(sprintf("Stripping %d singleton plates to protect ComBat linear independence...\n", length(singleton_plates)))
  valid_indices <- !mrna_metadata$plate_id %in% singleton_plates
  vst_matrix <- vst_matrix[, valid_indices]
  mrna_metadata <- mrna_metadata[valid_indices, ]
}

batch_vector <- as.factor(mrna_metadata$plate_id)
mod_matrix <- model.matrix(~ as.factor(class), data = mrna_metadata)

cat("Executing ComBat for plate batch effects...\n")
mrna_corrected <- ComBat(dat = vst_matrix, 
                         batch = batch_vector, 
                         mod = mod_matrix, 
                         par.prior = TRUE, 
                         prior.plots = FALSE)

# Save intermediate matrix
saveRDS(list(matrix = mrna_corrected, metadata = mrna_metadata), 
        file = file.path(config$out_dir, "mrna_normalized_corrected.rds"))
