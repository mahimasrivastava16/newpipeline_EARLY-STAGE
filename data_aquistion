  raw_dir   = "data/raw",          # Where GDCdownload saves raw .rda files
  out_dir   = "data/processed",    # Where processed .rda files are saved
  plot_dir  = "results/plots/qc",  # QC plots
  csv_dir   = "results/tables",    # Exported CSV tables

  # External annotation files (download before running)
