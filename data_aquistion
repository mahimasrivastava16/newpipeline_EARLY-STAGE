  #   MediaObjects/13059_2016_1066_MOESM1_ESM.csv
  pidsley_file    = "data/annotations/pidsley_cross_reactive_probes.csv",

  # TCGA RPPA antibody annotations (download from GDC):
  #   https://gdc.cancer.gov/about-data/publications/pancanatlas
  antibody_anno   = "data/annotations/TCGA_antibodies_descriptions.gencode.v36.tsv",

  # Clinical metadata (generated after MOFA, or pre-prepared from TCGA clinical data)
  clin_csv        = "data/clinical/common_samples_clinical.csv",

  # GDC project
  project         = "TCGA-BRCA",

  # Reproducibility seed
  seed            = 42L
